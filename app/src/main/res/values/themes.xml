<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base theme -->
    <style name="Theme.QAxion" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- NoActionBar for WebView activity -->
    <style name="Theme.QAxion.NoActionBar">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.QAxion.Splash">
        <item name="android:statusBarColor">@color/splash_bg_start</item>
        <item name="android:navigationBarColor">@color/splash_bg_end</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@drawable/bg_splash</item>
    </style>

    <!-- Dialog style -->
    <style name="QAxionDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/surface</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/QAxionDialogTitle</item>
        <item name="buttonBarPositiveButtonStyle">@style/QAxionDialogButton</item>
    </style>

    <style name="QAxionDialogTitle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="QAxionDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary</item>
    </style>

</resources>
